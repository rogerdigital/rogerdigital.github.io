---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang?: string;
  backLink?: { label: string; href: string };
}

const { title, description, lang = 'en', backLink } = Astro.props;
---

<!doctype html>
<html lang={lang} data-theme="dark" data-theme-choice="system">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://rogerdigital.github.io" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <script is:inline>
      (() => {
        const storageKey = 'rogerdigital-theme';
        const root = document.documentElement;
        const media = window.matchMedia('(prefers-color-scheme: light)');
        const stored = localStorage.getItem(storageKey);
        const choice = ['light', 'dark', 'system'].includes(stored || '') ? stored : 'system';
        const resolved = choice === 'system' ? (media.matches ? 'light' : 'dark') : choice;

        root.dataset.themeChoice = choice;
        root.dataset.theme = resolved;
        root.style.colorScheme = resolved;
      })();
    </script>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Source+Serif+4:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Nav backLink={backLink} />
    <slot />
    <Footer />
  </body>
</html>
