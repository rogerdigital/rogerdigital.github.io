---
interface Props {
  title: string;
  description: string;
  tags: string[];
  repoUrl: string;
}

const { title, description, tags, repoUrl } = Astro.props;
---

<div class="card project-card">
  <h3>{title}</h3>
  <p>{description}</p>
  <div class="tech-tags">
    {tags.map((tag) => <span>{tag}</span>)}
  </div>
  <p class="links-row">
    <a href={repoUrl} target="_blank" rel="noreferrer">Repository →</a>
  </p>
</div>
