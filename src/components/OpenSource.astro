---
import { contributions, getByProject, getProjects } from "../data/oss-contributions";

const MAX_DISPLAY = 3;
const projects = getProjects();
---

<section id="oss" class="section">
  <div class="section-header">
    <h2>Open Source</h2>
    <p class="section-note">Open-source projects I contribute to.</p>
  </div>

  {projects.map((project, idx) => {
    const prs = getByProject(project.name);
    const displayed = prs.slice(0, MAX_DISPLAY);
    const hasMore = prs.length > MAX_DISPLAY;
    const slug = project.name.toLowerCase().replace(/\s+/g, "-");

    return (
      <div style={idx > 0 ? "margin-top: 40px; padding-top: 24px; border-top: 1px solid var(--color-border);" : ""}>
        <h3 class="flat-group-title">{project.name}</h3>
        <p class="flat-group-desc">
          <a href={project.url} target="_blank" rel="noreferrer">Project →</a>
        </p>

        <p class="card-label">Selected Contributions</p>

        {displayed.map((pr) => (
          <div class="flat-item">
            <h4><a href={pr.url} target="_blank" rel="noreferrer">{pr.title}</a></h4>
            <p>{pr.description}</p>
          </div>
        ))}

        {hasMore && (
          <div style="margin-top: 16px;">
            <a href={`/oss/${slug}`} class="button">All PRs →</a>
          </div>
        )}
      </div>
    );
  })}
</section>
