---
const categories = [
  {
    title: 'Editor & Dev',
    items: ['Neovim', 'VS Code', 'iTerm2', 'Claude Code'],
  },
  {
    title: 'Languages',
    items: ['Swift', 'Python', 'TypeScript', 'Go'],
  },
  {
    title: 'Productivity',
    items: ['Linear', 'Notion', 'Arc Browser'],
  },
  {
    title: 'Hardware',
    items: ['MacBook Pro 14"'],
  },
];
---

<section id="uses" class="section">
  <div class="section-header">
    <h2>Uses</h2>
    <p class="section-note">Tools and setup I use daily.</p>
  </div>
  <div>
    {categories.map((cat) => (
      <div class="flat-item uses-category">
        <p class="card-label">{cat.title}</p>
        <p class="uses-flat-items">{cat.items.join(' · ')}</p>
      </div>
    ))}
  </div>
</section>
