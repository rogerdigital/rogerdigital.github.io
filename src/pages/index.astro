---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ProjectCard from "../components/ProjectCard.astro";
---

<BaseLayout
  title="Roger Deng | AI-native Builder"
  description="Building AI-native products, autonomous agents, and developer tools."
>
  <Hero />

  <section class="section">
    <div class="section-header">
      <h2>About</h2>
    </div>
    <div class="focus-summary">
      <p>
        iOS engineer building at the intersection of AI and product.
        Currently focused on autonomous quantitative trading (QuantPilot)
        and multi-platform publishing workflows (Publio).
      </p>
      <p>
        Contributing to open-source AI assistants and exploring robotics,
        digital biology, and frontier technology.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>Featured Work</h2>
      <p class="section-note">Selected projects and open-source contributions.</p>
    </div>
    <div class="project-grid">
      <ProjectCard
        title="QuantPilot"
        description="Autonomous quantitative trading platform with agent-driven decision workflows."
        link="https://github.com/rogerdigital/quantpilot"
      />
      <ProjectCard
        title="Publio"
        description="Multi-platform publishing tool — write once, distribute everywhere."
        link="https://github.com/rogerdigital/publio"
      />
      <ProjectCard
        title="OpenClaw"
        description="Open-source AI assistant. Contributions to TUI streaming, WhatsApp voice transcription, and session management."
        link="https://github.com/openclaw/openclaw"
        linkLabel="Project"
      />
    </div>
    <p class="links-row" style="margin-top:16px;">
      <a href="/projects">View all projects &amp; contributions &rarr;</a>
    </p>
  </section>

  <section class="section contact-section">
    <div class="section-header">
      <h2>Connect</h2>
    </div>
    <div class="card">
      <p>
        GitHub:
        <a href="https://github.com/rogerdigital" target="_blank" rel="noreferrer">@rogerdigital</a>
      </p>
    </div>
  </section>
</BaseLayout>
