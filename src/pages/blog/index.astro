---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Blog | Roger Deng"
  description="Thoughts on engineering, AI, and tools."
>
  <main class="container">
    <section class="hero">
      <h1>Writing</h1>
      <p class="subtitle">Thoughts on engineering, AI, and tools.</p>
    </section>

    <section class="section">
      {posts.length === 0 && (
        <div class="card">
          <p>No posts yet. Check back soon.</p>
        </div>
      )}
      {posts.map((post) => {
        const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
        });
        return (
          <div class="writing-item">
            <h3><a href={`/blog/${post.id}`}>{post.data.title}</a></h3>
            <p>{post.data.description}</p>
            <p class="writing-meta">{formattedDate}</p>
          </div>
        );
      })}
    </section>
  </main>
</BaseLayout>
