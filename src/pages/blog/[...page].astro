---
import type { GetStaticPaths } from "astro";
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection('blog');
  const posts = allPosts
    .filter(({ data }) => !data.draft)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return paginate(posts, { pageSize: 15 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<BaseLayout
  title="Blog | Roger Deng"
  description="Thoughts on engineering, AI, and tools."
>
  <main class="container">
    <section class="hero">
      <h1>Writing</h1>
      <p class="subtitle">Thoughts on engineering, AI, and tools.</p>
    </section>

    <section class="section">
      {page.data.length === 0 && (
        <div class="card">
          <p>No posts yet. Check back soon.</p>
        </div>
      )}
      {page.data.map((post) => {
        const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
        });
        return (
          <div class="writing-item">
            <h3><a href={`/blog/${post.id}`}>{post.data.title}</a></h3>
            <p>{post.data.description}</p>
            <p class="writing-meta">{formattedDate}</p>
          </div>
        );
      })}

      {page.lastPage > 1 && (
        <nav class="pagination">
          {page.url.prev ? (
            <a href={page.url.prev} class="pagination-link">← Prev</a>
          ) : (
            <span class="pagination-link disabled">← Prev</span>
          )}

          {Array.from({ length: page.lastPage }, (_, i) => i + 1).map((num) => (
            <a
              href={num === 1 ? "/blog" : `/blog/${num}`}
              class:list={["pagination-link", { active: num === page.currentPage }]}
            >
              {num}
            </a>
          ))}

          {page.url.next ? (
            <a href={page.url.next} class="pagination-link">Next →</a>
          ) : (
            <span class="pagination-link disabled">Next →</span>
          )}
        </nav>
      )}
    </section>
  </main>
</BaseLayout>
