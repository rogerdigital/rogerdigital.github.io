---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getByProject, getProjects } from '../data/oss-contributions';

const MAX_DISPLAY = 3;
const ossProjects = getProjects();

const groups = [
  {
    label: 'Products',
    projects: [
      {
        title: 'QuantPilot',
        description: 'Autonomous quantitative trading platform focused on agent-driven decision workflows.',
        tags: ['Python', 'Agent', 'Quant'],
        repoUrl: 'https://github.com/rogerdigital/quantpilot',
      },
      {
        title: 'Publio',
        description: 'Multi-platform publishing tool for writing once and distributing everywhere.',
        tags: ['TypeScript', 'Publishing'],
        repoUrl: 'https://github.com/rogerdigital/publio',
      },
    ],
  },
  {
    label: 'Obsidian Plugins',
    projects: [
      {
        title: 'Smart Explorer',
        description: 'Alternative file explorer with custom sorting, grouping, filtering, and lightweight previews.',
        tags: ['TypeScript', 'Obsidian'],
        repoUrl: 'https://github.com/rogerdigital/smart-explorer',
      },
      {
        title: 'Vault Inspector',
        description: 'Vault health checker that identifies broken links, orphan attachments, duplicates, and frontmatter drift.',
        tags: ['TypeScript', 'Obsidian'],
        repoUrl: 'https://github.com/rogerdigital/vault-inspector',
      },
      {
        title: 'Document Exporter',
        description: 'Export notes and folders as Markdown bundles, HTML documents, or print-ready PDFs.',
        tags: ['TypeScript', 'Obsidian'],
        repoUrl: 'https://github.com/rogerdigital/document-exporter',
      },
    ],
  },
];
---

<BaseLayout
  title="Projects | Roger Deng"
  description="Selected work across autonomous decision systems, publishing workflows, Obsidian plugins, and open-source contributions."
>
  <main class="container">
    <section class="section">
      <div class="section-header">
        <h2>Projects</h2>
        <p class="section-note">Selected work across autonomous systems, publishing workflows, and developer tools.</p>
      </div>

      {groups.map((group, idx) => (
        <div style={idx > 0 ? 'margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--color-border);' : ''}>
          <h3 class="flat-group-title">{group.label}</h3>
          {group.projects.map((p) => (
            <div class="flat-item">
              <h4><a href={p.repoUrl} target="_blank" rel="noreferrer">{p.title}</a></h4>
              <p>{p.description}</p>
              <div class="tech-tags">
                {p.tags.map((tag) => <span>{tag}</span>)}
              </div>
            </div>
          ))}
        </div>
      ))}
    </section>

    <section class="section">
      <div class="section-header">
        <h2>Open Source</h2>
        <p class="section-note">Open-source projects I contribute to, plus concrete merged work.</p>
      </div>

      {ossProjects.map((project, idx) => {
        const prs = getByProject(project.name);
        const displayed = prs.slice(0, MAX_DISPLAY);
        const hasMore = prs.length > MAX_DISPLAY;
        const slug = project.name.toLowerCase().replace(/\s+/g, "-");

        return (
          <div style={idx > 0 ? "margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--color-border);" : "margin-top: 32px;"}>
            <h3 class="flat-group-title">{project.name}</h3>
            <p class="flat-group-desc">
              <a href={project.url} target="_blank" rel="noreferrer">Project →</a>
            </p>

            <p class="card-label">Selected Contributions</p>

            {displayed.map((pr) => (
              <div class="flat-item">
                <h4><a href={pr.url} target="_blank" rel="noreferrer">{pr.title}</a></h4>
                <p>{pr.description}</p>
              </div>
            ))}

            {hasMore && (
              <div style="margin-top: 16px;">
                <a href={`/oss/${slug}`} class="button">All PRs →</a>
              </div>
            )}
          </div>
        );
      })}
    </section>
  </main>
</BaseLayout>
